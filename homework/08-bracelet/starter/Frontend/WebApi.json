{
  "openapi": "3.0.1",
  "info": {
    "title": "WebApi | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/ping": {
      "get": {
        "tags": [
          "WebApi"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResultDto"
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": [
          "OrderEndpoints"
        ],
        "operationId": "GetOrders",
        "parameters": [
          {
            "name": "minCost",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OrderDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "OrderEndpoints"
        ],
        "operationId": "CreateOrder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": [
          "OrderEndpoints"
        ],
        "operationId": "GetOrderById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetailDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/bracelets/validate/{data}": {
      "get": {
        "tags": [
          "OrderEndpoints"
        ],
        "operationId": "ValidateBracelet",
        "parameters": [
          {
            "name": "data",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BraceletDto": {
        "required": [
          "id",
          "braceletData",
          "cost"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "braceletData": {
            "type": "string"
          },
          "cost": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "CreateOrderDto": {
        "required": [
          "customerName",
          "address",
          "braceletData"
        ],
        "type": "object",
        "properties": {
          "customerName": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "braceletData": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "OrderDetailDto": {
        "required": [
          "id",
          "customerName",
          "orderDate",
          "totalCost",
          "numberOfBracelets",
          "orderItems"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "customerName": {
            "type": "string"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalCost": {
            "type": "number",
            "format": "double"
          },
          "numberOfBracelets": {
            "type": "integer",
            "format": "int32"
          },
          "orderItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BraceletDto"
            }
          }
        }
      },
      "OrderDto": {
        "required": [
          "id",
          "customerName",
          "orderDate",
          "totalCost",
          "numberOfBracelets"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "customerName": {
            "type": "string"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalCost": {
            "type": "number",
            "format": "double"
          },
          "numberOfBracelets": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PingResultDto": {
        "required": [
          "message",
          "timestamp"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ValidationResult": {
        "required": [
          "error",
          "mixedColorWarning",
          "cost"
        ],
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "nullable": true
          },
          "mixedColorWarning": {
            "type": "boolean"
          },
          "cost": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "WebApi"
    },
    {
      "name": "OrderEndpoints"
    }
  ]
}