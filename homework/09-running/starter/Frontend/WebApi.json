            "type": "integer",
            "format": "int32"
          }
        }
      },
      "EvaluationDto": {
        "required": [
          "totalTime",
          "avgVelocity",
          "goalAchieved",
          "splits"
        ],
        "type": "object",
        "properties": {
          "totalTime": {
            "type": "integer",
            "format": "int32"
          },
          "avgVelocity": {
            "type": "integer",
            "format": "int32"
          },
          "goalAchieved": {
            "type": "boolean"
          },
          "splits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SplitDto"
            }
          }
        }
      },
      "PartitionerDto": {
        "required": [
          "id",
          "startNr",
          "firstName",
          "lastName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "startNr": {
            "type": "integer",
            "format": "int32"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          }
        }
      },
      "SplitDto": {
        "required": [
          "km",
          "length",
          "time",
          "avgVelocity",
          "goalAchieved"
        ],
        "type": "object",
        "properties": {
          "km": {
            "type": "integer",
            "format": "int32"
          },
          "length": {
            "type": "integer",
            "format": "int32"
          },
          "time": {
            "type": "string"
          },
          "avgVelocity": {
            "type": "string"
          },
          "goalAchieved": {
            "type": "boolean"
          }
        }
