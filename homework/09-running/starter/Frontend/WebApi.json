            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CompetitionDto": {
        "required": [
          "id",
          "name",
          "category",
          "length",
          "date",
          "place"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "$ref": "#/components/schemas/CategoryDto"
          },
          "length": {
            "type": "number",
            "format": "double"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "place": {
            "type": "string"
          }
        }
      },
      "CompetitionReqDto": {
        "required": [
          "name",
          "category",
          "length",
          "place"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "category": {
            "$ref": "#/components/schemas/CategoryDto"
          },
          "length": {
            "type": "number",
            "format": "double"
          },
          "place": {
            "type": "string"
          }
        }
      },
      "EvalReqDto": {
        "required": [
          "partitionerId"
        ],
        "type": "object",
